# ─── App ────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/credit_analysis_engine?appName=<cluster>

# ─── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# ─── Pluggy ─────────────────────────────────────────────────────────────────────
PLUGGY_CLIENT_ID=your-pluggy-client-id
PLUGGY_CLIENT_SECRET=your-pluggy-client-secret
# Signing secret configured in Pluggy dashboard for webhook signature validation
PLUGGY_WEBHOOK_SECRET=your-webhook-signing-secret

# ─── Supabase (PostgreSQL) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# ─── External Dispatch System ────────────────────────────────────────────────────
EXTERNAL_SYSTEM_URL=https://api.external-system.com/ingest
EXTERNAL_SYSTEM_API_KEY=your-api-key

# ─── Resilience ─────────────────────────────────────────────────────────────────
DISPATCH_CONCURRENCY=3
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=2000
